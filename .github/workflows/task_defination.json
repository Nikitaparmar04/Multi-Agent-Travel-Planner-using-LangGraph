{
  "family": "llmopstdlive",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::982689564929:role/ecsTaskExecutionRole",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "8192",
  "containerDefinitions": [
    {
      "name": "tripmind-live-container",
      "image": "982689564929.dkr.ecr.us-east-1.amazonaws.com/tripmind-app",
      "cpu": 1024,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "name": "tripmind-8080",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "ENV",
          "value": "production"
        }
      ],
      "secrets": [
        {
          "name": "apikeyliveclass",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:982689564929:secret:llmops-Wz81Rv"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/llmopstdlive",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
